server_path = option('server-path');

let f = file("vala", `
void main() {
    print ("GLib is a string");
'}
`);

project_files = [ f ];

assert {
    diagnostics: [
        ...,
        {
            range: {
                start: { line: 3, character: 3 },
                end: { line: 3, character: 4 }
            },
            severity: DiagnosticSeverity.Error,
            message: "invalid character literal"
        },
        ...
    ]
} <=> await diagnostics(f);
